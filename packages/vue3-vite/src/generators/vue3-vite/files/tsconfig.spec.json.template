{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "<%= offsetFromRoot %>dist/out-tsc",
<% if (testFramework === 'jest') { -%>
    "module": "commonjs",
    "types": ["vue-i18n", "node"],
<% } else { -%>
    "types": ["vue-i18n", "vitest/globals", "node"],
<% } -%>
    "composite": true
  },
  "include": [
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.vue",
    "**/*.d.ts",
    "**/*.ts"
  ]
}
